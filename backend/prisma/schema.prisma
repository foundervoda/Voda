generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String       @id @default(uuid())
  email          String?      @unique
  phone          String
  role           Role
  password       String?
  storeId        String?
  createdAt      DateTime     @default(now())
  customerOrders Order[]      @relation("CustomerOrders")
  riderOrders    Order[]      @relation("RiderOrders")
  runnerOrders   Order[]      @relation("RunnerOrders")
  tnbRequests    TnbRequest[] @relation("TnbRequester")
  tnbResolutions TnbRequest[] @relation("TnbResolver")
  store          Store?       @relation(fields: [storeId], references: [id])
}

model Store {
  id          String    @id @default(uuid())
  name        String
  location    String
  createdAt   DateTime  @default(now())
  tbOverride  String    @default("NONE")
  tnbOverride Boolean?
  products    Product[]
  staff       User[]
}

model Product {
  id                String       @id @default(uuid())
  name              String
  price             Decimal
  images            String[]
  category          String
  trending          Boolean      @default(false)
  storeId           String
  tbEligible        Boolean?
  tbRequest         String?
  tryAndBuyEligible Boolean      @default(false)
  orderItems        OrderItem[]
  store             Store        @relation(fields: [storeId], references: [id])
  tnbRequests       TnbRequest[]
  variants          Variant[]
}

model Variant {
  id         String      @id @default(uuid())
  size       String
  color      String?
  stock      Int         @default(0)
  productId  String
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id])
}

model Order {
  id           String      @id @default(uuid())
  status       OrderStatus @default(PENDING)
  deliveryAddr String
  etaMinutes   Int
  tryTimerEnd  DateTime?
  customerId   String
  runnerId     String?
  riderId      String?
  createdAt    DateTime    @default(now())
  deliveryOtp  String?
  customer     User        @relation("CustomerOrders", fields: [customerId], references: [id])
  rider        User?       @relation("RiderOrders", fields: [riderId], references: [id])
  runner       User?       @relation("RunnerOrders", fields: [runnerId], references: [id])
  items        OrderItem[]
}

model OrderItem {
  id            String  @id @default(uuid())
  quantity      Int     @default(1)
  orderId       String
  productId     String
  variantId     String
  isReturned    Boolean @default(false)
  returnReason  String?
  returnComment String?
  order         Order   @relation(fields: [orderId], references: [id])
  product       Product @relation(fields: [productId], references: [id])
  variant       Variant @relation(fields: [variantId], references: [id])
}

model TnbCategoryDefault {
  category  String   @id
  eligible  Boolean
  updatedAt DateTime @updatedAt
}

model TnbRequest {
  id                String           @id @default(uuid())
  requestedEligible Boolean
  note              String?
  status            TnbRequestStatus @default(PENDING)
  productId         String
  requestedById     String
  resolvedById      String?
  resolvedAt        DateTime?
  createdAt         DateTime         @default(now())
  product           Product          @relation(fields: [productId], references: [id])
  requestedBy       User             @relation("TnbRequester", fields: [requestedById], references: [id])
  resolvedBy        User?            @relation("TnbResolver", fields: [resolvedById], references: [id])
}

enum Role {
  CUSTOMER
  RUNNER
  RIDER
  STORE_STAFF
  ADMIN
}

enum TnbRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  RUNNER_ASSIGNED
  COLLECTED
  HANDED_TO_RIDER
  OUT_FOR_DELIVERY
  ARRIVED
  TRY_BUY_IN_PROGRESS
  DELIVERED
  RETURNING
  RETURNED
  REFUNDED
}
